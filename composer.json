{
    "name": "themesberg/flowbite-blade",
    "description": "Flowbite UI components for Laravel Blade",
    "keywords": ["laravel", "blade", "flowbite", "tailwindcss", "components"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Themesberg\\FlowbiteBlade\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Themesberg\\FlowbiteBlade\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Themesberg\\FlowbiteBlade\\FlowbiteBladeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
